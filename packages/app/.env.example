# Used by the app at runtime (Expo inlines EXPO_PUBLIC_* into the bundle).
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_KEY=test-key
EXPO_PUBLIC_SENTRY_DSN=

# EAS Build: set the same EXPO_PUBLIC_* names (plus SENTRY_AUTH_TOKEN) as project
# secrets via `eas secret:create`. See packages/app/EAS.md.