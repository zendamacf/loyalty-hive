{
  "expo": {
    "name": "LoyaltyHive",
    "slug": "loyaltyhive",
    "scheme": "loyaltyhive",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "com.kalopsiaapps.loyaltyhive"
    },
    "android": {
      "package": "com.kalopsiaapps.loyaltyhive",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash-icon.png",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#0D1B2A"
          },
          "imageWidth": 200
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "loyalty-hive",
          "organization": "kalopsiadev"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30be6b50-4681-4019-b980-314e05e21478"
      }
    },
    "owner": "zendama_cf"
  }
}
