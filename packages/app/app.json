{
  "expo": {
    "name": "LoyaltyHive",
    "slug": "loyaltyhive",
    "scheme": "loyaltyhive",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B2A"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2"
    },
    "android": {
      "package": "com.kalopsiaapps.loyaltyhive",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D1B2A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "loyalty-hive",
          "organization": "kalopsiadev"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30be6b50-4681-4019-b980-314e05e21478"
      }
    },
    "owner": "zendama_cf"
  }
}