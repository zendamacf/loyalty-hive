{
  "name": "@loyalty-hive/app",
  "version": "1.1.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:android": "expo start --android",
    "android:prebuild": "expo prebuild --platform android --clean",
    "android:run": "expo run:android",
    "eas:init": "eas init",
    "build:android:development": "eas build --platform android --profile development",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "web": "expo start --web",
    "test": "bun test --preload ./test/setup.ts ./src ./test/routes",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "typecheck": "tsc --noEmit",
    "api:generate": "openapi-ts && bun run api:generate:hotfix",
    "api:generate:hotfix": "sed -i '1s;^;// @ts-expect-error Generated runtimeConfigPath import uses a .ts extension\\n;' src/lib/api-client/gen/client.gen.ts",
    "postversion": "react-native-version --never-amend"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.98.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@sentry/react-native": "7.11.0",
    "@tanstack/react-query": "^5.90.5",
    "babel-preset-expo": "~56.0.15",
    "dotenv": "^17.4.2",
    "expo": "~55.0.0",
    "expo-brightness": "~56.0.5",
    "expo-camera": "^55.0.0",
    "expo-clipboard": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-localization": "~55.0.0",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "hono": "^4.12.17",
    "i18next": "^26.2.0",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-actions-sheet": "^10.1.2",
    "react-native-barcode-svg": "^0.0.15",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-svg": "15.15.3",
    "react-native-version": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.10",
    "bun-types": "^1.3.13",
    "eas-cli": "^18.13.1",
    "react-native-dotenv": "^3.4.11",
    "react-native-svg-transformer": "1.5.3",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  }
}
