{
  "name": "@loyalty-hive/api",
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "prebuild": "node -p \"require('./package.json').version\"",
    "dev": "sh -c 'LIB_VERSION=$(npm run -s prebuild) exec bun --watch src/app.ts'",
    "start": "sh -c 'LIB_VERSION=$(npm run -s prebuild) exec node dist/app.js'",
    "test": "sh -c 'LIB_VERSION=$(npm run -s prebuild) exec bun test --preload ./test/setup.ts'",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/sentry": "^1.2.2",
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono-openapi": "^1.3.0",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@biomejs/biome": "2.4.14",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
